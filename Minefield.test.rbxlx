        <Item class="ModuleScript" referent="353">
          <Properties>
            <string name="Name">Landmine</string>
            <string name="Source"><![CDATA[local CollectionService = game:GetService("CollectionService")
local Players = game:GetService("Players")
local Debris = game:GetService("Debris")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local BasicNetwork = require(ReplicatedStorage.Shared.Utilities.BasicNetwork)
local RagdollService = require(ServerScriptService.Server.Services.RagdollService)

local Landmine = {}
Landmine.Tag = script.Name
Landmine.__index = Landmine

local LandmineExploded = BasicNetwork.new("LandmineExploded",false,false)

local ARM_TIME = 0.12
local DAMAGE = 45
local HORIZONTAL_FORCE = 150
local UPWARD_FORCE = 200
local RAGDOLL_DURATION = 2

local function getBasePart(instance)
	if instance:IsA("BasePart") then
		return instance
	end
	if instance:IsA("Model") then
		return instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart")
	end
	return nil
end

function Landmine.new(instance)
	local self = setmetatable({}, Landmine)
	self.instance = instance
	self.armed = false
	self.detonated = false
	self.part = getBasePart(instance)

	self:init()
	return self
end

function Landmine:init()
	if not self.part then
		warn("Landmine: missing part on", self.instance:GetFullName())
		return
	end

	self.part.Transparency = 1
	self.part.CanCollide = false
	self.part.CanTouch = true

	self.part.Touched:Connect(function(hit)
		local character = hit:FindFirstAncestorOfClass("Model")
		local player = character and Players:GetPlayerFromCharacter(character)
		if not player then
			return
		end
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			self:arm(humanoid)
		end
	end)
end

function Landmine:arm(humanoid)
	if self.armed or self.detonated then
		return
	end
	self.armed = true
	self.lastHumanoid = humanoid

	task.delay(ARM_TIME, function()
		self:detonate()
	end)
end

function Landmine:detonate()
	if self.detonated then
		return
	end
	self.detonated = true

	LandmineExploded:FireAllClients(self.instance, self.part.CFrame)

	local humanoid = self.lastHumanoid
	if humanoid and humanoid.Health > 0 then
		humanoid:TakeDamage(DAMAGE)
		RagdollService:RagdollCharacter(humanoid.Parent, RAGDOLL_DURATION)

		local rootPart = humanoid.RootPart
		if rootPart then
			local flingDirection = rootPart.CFrame.LookVector
			if flingDirection.Magnitude < 0.001 then
				flingDirection = Vector3.new(0, 0, -1)
			end
			rootPart.AssemblyLinearVelocity = (flingDirection.Unit * HORIZONTAL_FORCE) + Vector3.new(0, UPWARD_FORCE, 0)
		end

		
	end

	self.part.Transparency = 1
	self.part.CanCollide = false

	CollectionService:RemoveTag(self.instance, Landmine.Tag)

	Debris:AddItem(self.part, 2)
	if self.instance ~= self.part and self.instance.Parent then
		Debris:AddItem(self.instance, 2)
	end

	self:destroy()
end

function Landmine:destroy()
	print("Landmine component destroyed for", self.instance:GetFullName())
	if self.instance and self.instance.Parent and not self.detonated then
		self.instance:Destroy()
	end
end

return Landmine
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="354">
          <Properties>
            <string name="Name">LavaSpinner</string>
            <string name="Source"><![CDATA[local RunService = game:GetService("RunService")

local LavaSpinner = {}
LavaSpinner.Tag = script.Name
LavaSpinner.__index = LavaSpinner

local function getBasePart(instance)
	if instance:IsA("BasePart") then
		return instance
	end
	if instance:IsA("Model") then
		return instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart")
	end
	return nil
end

local function damageHumanoid(hit, amount)
	local character = hit and hit.Parent
	if not character then
		return
	end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.Health > 0 then
		humanoid:TakeDamage(amount)
	end
end

function LavaSpinner.new(instance)
	local self = setmetatable({}, LavaSpinner)
	self.instance = instance
	self.part = getBasePart(instance)
	self.active = true

	self:init()
	return self
end

function LavaSpinner:init()
	if not self.part then
		warn("LavaSpinner: missing part on", self.instance:GetFullName())
		return
	end

	self.spinner = Instance.new("Part")
	self.spinner.Name = "LavaSpinnerBlade"
	self.spinner.Size = Vector3.new(self.part.Size.X * 0.8, 1, 1)
	self.spinner.Anchored = true
	self.spinner.CanCollide = false
	self.spinner.Transparency = 0.3
	self.spinner.Material = Enum.Material.Neon
	self.spinner.BrickColor = BrickColor.new("Bright orange")
	self.spinner.CFrame = self.part.CFrame * CFrame.new(0, 2.5, 0)
	self.spinner.Parent = self.part

	self.spinner.Touched:Connect(function(hit)
		damageHumanoid(hit, 15)
	end)

	RunService.Heartbeat:Connect(function(dt)
		if not self.active or not self.spinner.Parent then
			return
		end
		self.spinner.CFrame = self.spinner.CFrame * CFrame.Angles(0, math.rad(160 * dt), 0)
	end)
end

function LavaSpinner:destroy()
	self.active = false
	if self.spinner then
		self.spinner:Destroy()
	end
	print("LavaSpinner component destroyed for", self.instance:GetFullName())
end

return LavaSpinner
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="355">
