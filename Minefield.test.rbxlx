	math.pow(2, 32) - 1,
	math.pow(2, 16) - 1,
	math.pow(2, 8) - 1,
	-math.pow(2, 31),
	-math.pow(2, 16),
	-math.pow(2, 7),
}

TestHelper.dataType(require(script.Parent.number), {
