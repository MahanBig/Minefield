        <Item class="Folder" referent="252">
          <Properties>
            <string name="Name">miagobble_anti-anthro@1.0.1</string>
          </Properties>
          <Item class="ModuleScript" referent="253">
            <Properties>
              <string name="Name">anti-anthro</string>
              <string name="Source">--[=[
	@class AntiAnthro

	Force your game to be in R6, even if it's set to R15 in game settings.

	This is drop-in! Just require the module and call `HookToGame()` before everything else, like so:

	```lua
	local AntiAnthro = require(path.to.AntiAnthro)

	AntiAnthro.HookToGame()
	```
]=]

local AntiAnthro = {}

-- Services
local PlayersService = game:GetService("Players")
local StarterPlayer = game:GetService("StarterPlayer")

local function ApplyDescription(character : Model)
	local Humanoid : Humanoid = character:FindFirstChild("Humanoid")
	local Player : Player = PlayersService:GetPlayerFromCharacter(character)
	
	if not Humanoid then
		error(`No humanoid found in character ({character:GetFullName()})`)
		return
	end
	
	if not Player then
		error(`No player found for character ({character:GetFullName()})`)
		return
	end
	
	local Description : HumanoidDescription = Player:FindFirstChild("_DESCRIPTION_CACHE")
	
	if not Description then
		local NewDescription : HumanoidDescription = PlayersService:GetHumanoidDescriptionFromUserIdAsync(Player.UserId)
		NewDescription.Name = "_DESCRIPTION_CACHE"
		NewDescription.Parent = Player
		Description = NewDescription
	end

	Humanoid:ApplyDescriptionAsync(Description)
end

local function HookToPlayer(player : Player)
	if player.Character then
		task.spawn(ApplyDescription, player.Character)
	end
	
	player.CharacterAdded:Connect(ApplyDescription)
end

--[=[
	Hooks the AntiAnthro module to the game, applying the necessary modifications to characters.
]=]

function AntiAnthro.HookToGame()
	local StarterCharacter = script:FindFirstChild("StarterCharacter")
	
	if not StarterCharacter then
		return
	end
	
	StarterCharacter.Parent = StarterPlayer
	
	for _, player : Player in PlayersService:GetPlayers() do
		HookToPlayer(player)
	end
	
	PlayersService.PlayerAdded:Connect(HookToPlayer)
end

return AntiAnthro</string>
