                  <Item class="ModuleScript" referent="169">
                    <Properties>
                      <string name="Name">Region3</string>
                      <string name="Source"><![CDATA[local dataTypesRoot = script:FindFirstAncestor("DataTypes")
local DataTypeDefinition = require(dataTypesRoot.DataTypeDefinition)

return DataTypeDefinition.new("Region3", {
	read = function(stream)
		local vMin = Vector3.new(stream:readf32(), stream:readf32(), stream:readf32())
		local vMax = Vector3.new(stream:readf32(), stream:readf32(), stream:readf32())
		return Region3.new(vMin, vMax)
	end,
	write = function(stream, r3)
		local sx, sy, sz = r3.Size.X / 2, r3.Size.Y / 2, r3.Size.Z / 2
		local vMin = r3.CFrame * Vector3.new(-sx, -sy, -sz)
		local vMax = r3.CFrame * Vector3.new(sx, sy, sz)

		stream:writef32(math.min(vMin.X, vMax.X))
		stream:writef32(math.min(vMin.Y, vMax.Y))
		stream:writef32(math.min(vMin.Z, vMax.Z))
		stream:writef32(math.max(vMin.X, vMax.X))
		stream:writef32(math.max(vMin.Y, vMax.Y))
		stream:writef32(math.max(vMin.Z, vMax.Z))
	end,
})
]]></string>
                    </Properties>
                  </Item>
                  <Item class="ModuleScript" referent="170">
                    <Properties>
                      <string name="Name">Region3.spec</string>
                      <string name="Source"><![CDATA[local TestHelper = require(game.ReplicatedStorage.DevPackages.TestHelper)

local VALUES = {
	Region3.new(Vector3.new(1, 2, 3), Vector3.new(4, 5, 6)),
	Region3.new(Vector3.new(-1, -2, -3), Vector3.new(4, 5, 6)),
	Region3.new(Vector3.new(-math.pi, -math.pi, -math.pi), Vector3.new(4, 5, 6)), -- not lossless?
}

TestHelper.dataType(require(script.Parent.Region3), {
	values = table.pack(table.unpack(VALUES)),
	compare = function(a, b)
		-- I do not for the life of me understand why this isn't losslessly encoding.
		-- I confirmed that the vMin and vMax components save and load to the buffer, but
		-- it seems like when you plug them into the Region3 constructor the value can change??!?
		return a.Size == b.Size and a.CFrame:FuzzyEq(b.CFrame)
	end,
})
]]></string>
                    </Properties>
                  </Item>
                  <Item class="ModuleScript" referent="171">
                    <Properties>
                      <string name="Name">Region3int16</string>
                      <string name="Source"><![CDATA[local dataTypesRoot = script:FindFirstAncestor("DataTypes")
local DataTypeDefinition = require(dataTypesRoot.DataTypeDefinition)

return DataTypeDefinition.new("Region3int16", {
	read = function(stream)
		local vMin = Vector3int16.new(stream:readi16(), stream:readi16(), stream:readi16())
		local vMax = Vector3int16.new(stream:readi16(), stream:readi16(), stream:readi16())
		return Region3int16.new(vMin, vMax)
	end,
	write = function(stream, r3int16)
		local r3Min = r3int16.Min
		local r3Max = r3int16.Max

		stream:writei16(r3Min.X)
		stream:writei16(r3Min.Y)
		stream:writei16(r3Min.Z)
		stream:writei16(r3Max.X)
		stream:writei16(r3Max.Y)
		stream:writei16(r3Max.Z)
	end,
})
]]></string>
